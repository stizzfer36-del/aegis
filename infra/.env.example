# AEGIS Environment Variables
# Copy to .env and fill in values

# LLM Providers (at least one required)
OLLAMA_URL=http://localhost:11434
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=

# Default model to use with Ollama
AEGIS_DEFAULT_MODEL=mistral

# Telegram (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# NATS (optional - defaults to in-process)
NATS_URL=nats://localhost:4222

# Data storage directory
AEGIS_DATA_DIR=.aegis

# Home Assistant (for hardware_iot topic)
HASS_URL=http://homeassistant.local:8123
HASS_TOKEN=

# OctoPrint (for three_d_printing topic)
OCTOPRINT_URL=http://octopi.local
OCTOPRINT_API_KEY=

# Stable Diffusion (for image_generation topic)
A1111_URL=http://localhost:7860

# Sports Betting
ODDS_API_KEY=

# Finance
ETH_RPC_URL=https://eth.public-rpc.com

# Search
MEILI_URL=http://localhost:7700
MEILI_KEY=

# Comms
APPRISE_URLS=
MASTODON_URL=
MASTODON_TOKEN=
